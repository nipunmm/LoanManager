@{
    ViewData["Title"] = "Home Page";
}

<h2>Welcome, @ViewBag.Username!</h2>

<div class="mb-3">
    <a class="btn btn-primary" asp-controller="Home" asp-action="AddCustomer">Add Customer</a>
    <a class="btn btn-success" asp-controller="Home" asp-action="CreateLoan">Create Loan</a>
</div>

<h3>Loans</h3>

@{
    var loans = ViewBag.Loans as List<LoanManager.Models.LoanListItem>;
}

@if (loans != null && loans.Count > 0)
{
    <table class="table">
        <thead>
            <tr>
                <th>Loan ID</th>
                <th>Customer</th>
                <th>Identity Number</th>
                <th>Loan Type</th>
                <th>Amount</th>
                <th>Interest</th>
                <th>Duration</th>
                <th>Flow</th>
                <th>Created At</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var l in loans)
        {
            <tr>
                <td>@l.LoanId</td>
                <td>@l.CustomerName</td>
                <td>@l.IdentityNumber</td>
                <td>@l.LoanTypeName</td>
                <td>@l.LoanAmount</td>
                <td>@l.InterestRate</td>
                <td>@l.LoanDuration</td>
                <td>@l.CurrentFlow</td>
                <td>@l.CreatedAt</td>
                <td><a asp-controller="Loan" asp-action="Details" asp-route-id="@l.LoanId">Details</a></td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No loans found.</p>
}
